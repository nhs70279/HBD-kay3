<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BIRTHDAY AGENT - 極上ケーキ奪還作戦</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@600;800&family=Inter:wght@300;400;600&family=Noto+Sans+JP:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', 'Noto Sans JP', sans-serif;
            background-color: #F5EFEB;
            color: #3D3530;
            overflow: hidden;
            touch-action: manipulation;
        }
        .font-cinzel {
            font-family: 'Cinzel', serif;
        }
        .fade-in {
            animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .flame {
            animation: flicker 1s infinite alternate ease-in-out;
            transform-origin: center bottom;
        }
        @keyframes flicker {
            0% { transform: scale(1) rotate(-1.5deg); fill: #FF8A5B; }
            50% { transform: scale(1.1) rotate(2deg); fill: #FF5A5F; }
            100% { transform: scale(0.95) rotate(-1deg); fill: #FFB356; }
        }
        .floating {
            animation: float 4s ease-in-out infinite;
        }
        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-8px) rotate(1deg); }
        }
        .interactive-element:hover {
            filter: brightness(1.15) drop-shadow(0 0 4px rgba(212, 163, 115, 0.6));
            cursor: pointer;
        }
        /* スクロールバー非表示 */
        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-thumb {
            background: #D4A373;
            border-radius: 10px;
        }
    </style>
</head>
<body class="flex flex-col min-h-screen justify-between select-none relative w-full h-screen">

    <!-- 背景装飾 -->
    <div class="fixed top-[-10%] left-[-10%] w-[50vw] h-[50vw] bg-[#EADCC9] rounded-full blur-[120px] pointer-events-none z-0"></div>
    <div class="fixed bottom-[-10%] right-[-10%] w-[60vw] h-[60vw] bg-[#E6DFD3] rounded-full blur-[140px] pointer-events-none z-0"></div>

    <!-- コンフェッティ（紙吹雪）用キャンバス -->
    <canvas id="confetti-canvas" class="fixed inset-0 w-full h-full pointer-events-none z-50"></canvas>

    <!-- メインフレーム -->
    <main class="flex-grow flex items-center justify-center p-3 md:p-6 z-10 w-full max-w-4xl mx-auto h-full overflow-hidden">
        
        <div id="game-card" class="bg-white/85 backdrop-blur-lg rounded-[2rem] shadow-2xl shadow-[#3C3530]/10 border border-white/50 w-full h-[92vh] md:h-[800px] flex flex-col justify-between overflow-hidden relative fade-in">
            
            <!-- ヘッダー（ステータス＆インベントリ） -->
            <div id="game-header" class="hidden border-b border-[#E6DFD3] px-5 py-3 flex items-center justify-between bg-white/50 z-20">
                <div class="flex items-center space-x-2">
                    <span class="inline-block w-2.5 h-2.5 rounded-full bg-[#E27373] animate-ping"></span>
                    <span class="text-[10px] tracking-[0.2em] uppercase font-cinzel text-[#85705D] font-bold">Birthday Agent: Active</span>
                </div>
                <!-- インベントリ（スロットを4つに拡張） -->
                <div class="flex items-center space-x-2">
                    <span class="text-[9px] tracking-wider text-[#85705D] uppercase font-semibold">BAG:</span>
                    <div id="inventory-slots" class="flex gap-1.5">
                        <!-- スロット1 -->
                        <div id="slot-0" class="w-8 h-8 rounded-lg border border-[#E6DFD3] bg-white/60 flex items-center justify-center text-sm opacity-40 transition-all duration-300">📁</div>
                        <!-- スロット2 -->
                        <div id="slot-1" class="w-8 h-8 rounded-lg border border-[#E6DFD3] bg-white/60 flex items-center justify-center text-sm opacity-40 transition-all duration-300">📁</div>
                        <!-- スロット3 -->
                        <div id="slot-2" class="w-8 h-8 rounded-lg border border-[#E6DFD3] bg-white/60 flex items-center justify-center text-sm opacity-40 transition-all duration-300">📁</div>
                        <!-- スロット4（追加） -->
                        <div id="slot-3" class="w-8 h-8 rounded-lg border border-[#E6DFD3] bg-white/60 flex items-center justify-center text-sm opacity-40 transition-all duration-300">📁</div>
                    </div>
                </div>
            </div>

            <!-- メインボディ -->
            <div id="game-body" class="flex-grow flex flex-col md:flex-row p-4 md:p-6 gap-4 md:gap-6 items-stretch overflow-hidden">
                
                <!-- 左：インタラクティブ・ビジュアルエリア -->
                <div class="w-full md:w-1/2 flex items-center justify-center min-h-[220px] md:min-h-[auto] relative bg-[#FAF8F5] rounded-2xl border border-[#EBE4D8] overflow-hidden group shadow-inner" id="visual-area">
                    <!-- インタラクティブなSVGがここに注入されます -->
                </div>

                <!-- 右：ナレーション＆入力操作エリア -->
                <div class="w-full md:w-1/2 flex flex-col justify-between min-h-[240px] md:min-h-[auto] overflow-hidden bg-white/30 p-4 rounded-2xl border border-[#F0EAE1]">
                    
                    <!-- ナレーション・セリフログ -->
                    <div class="flex-grow flex flex-col overflow-y-auto pr-1" id="text-log-container">
                        <div id="location-indicator" class="text-[10px] tracking-widest text-[#A39281] font-bold uppercase mb-1">System Signal</div>
                        <div id="dialogue-text" class="text-xs md:text-sm leading-relaxed text-[#4A433D] whitespace-pre-line font-medium">
                            Initializing...
                        </div>
                        <!-- チャットログ（AI交渉フェーズのみ出現） -->
                        <div id="ai-chat-box" class="hidden flex-col gap-2 mt-3 pt-3 border-t border-[#EBE4D8] text-xs">
                            <!-- メッセージ履歴が動的に挿入されます -->
                        </div>
                    </div>

                    <!-- 下部：インタラクション / 選択肢 -->
                    <div class="mt-4 flex flex-col gap-2 flex-shrink-0">
                        <!-- AIチャットテキスト入力欄（AI交渉時のみアクティブ） -->
                        <div id="ai-input-panel" class="hidden w-full gap-2 items-center bg-white border border-[#E6DFD3] p-1.5 rounded-xl">
                            <input type="text" id="ai-user-text" class="flex-grow bg-transparent px-3 py-1.5 text-xs outline-none focus:ring-0 text-[#4A433D]" placeholder="うさぴょんに優しく話しかけてみよう..." onkeydown="if(event.key==='Enter') sendChatMessage()">
                            <button onclick="sendChatMessage()" id="ai-send-btn" class="bg-[#85705D] hover:bg-[#6F5B4B] text-white px-4 py-1.5 rounded-lg text-xs font-semibold transition-colors">
                                送信
                            </button>
                        </div>

                        <!-- 通常のアクションボタンパネル -->
                        <div id="action-panel" class="flex flex-col gap-1.5">
                            <!-- 動的にボタンが生成されます -->
                        </div>
                    </div>
                </div>

            </div>

            <!-- フッター -->
            <div class="border-t border-[#F0EAE1] px-6 py-3 flex justify-between items-center bg-white/40 text-[9px] text-[#A39281] z-20">
                <div class="tracking-widest font-semibold">MISSION ID: 2026-BIRTHDAY-CAKE</div>
                <div class="flex items-center gap-3">
                    <button onclick="toggleMusic()" id="music-btn" class="hover:text-[#85705D] transition-colors flex items-center gap-1 font-bold">
                        🎵 BGM: OFF
                    </button>
                    <button onclick="toggleMute()" id="mute-btn" class="hover:text-[#85705D] transition-colors flex items-center gap-1 font-bold">
                        🔊 SOUND: ON
                    </button>
                </div>
            </div>

        </div>
    </main>

    <script>
        // --- Web Audio API を用いた効果音・リアルタイムBGM演奏システム ---
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        let isMuted = false;
        let isMusicPlaying = false;
        let bgmIntervalId = null;
        let currentNoteIndex = 0;

        // ハッピーバースデートゥーユーの優しいオルゴール風メロディシーケンス
        const happyBirthdayMelody = [
            [261.63, 0.35, 0.05], [261.63, 0.15, 0.05], // C4, C4
            [293.66, 0.5, 0.05],  // D4
            [261.63, 0.5, 0.05],  // C4
            [349.23, 0.5, 0.05],  // F4
            [329.63, 1.0, 0.1],   // E4
            
            [261.63, 0.35, 0.05], [261.63, 0.15, 0.05], // C4, C4
            [293.66, 0.5, 0.05],  // D4
            [261.63, 0.5, 0.05],  // C4
            [392.00, 0.5, 0.05],  // G4
            [349.23, 1.0, 0.1],   // F4

            [261.63, 0.35, 0.05], [261.63, 0.15, 0.05], // C4, C4
            [523.25, 0.5, 0.05],  // C5
            [440.00, 0.5, 0.05],  // A4
            [349.23, 0.5, 0.05],  // F4
            [329.63, 0.5, 0.05],  // E4
            [293.66, 1.0, 0.1],   // D4

            [466.16, 0.35, 0.05], [466.16, 0.15, 0.05], // A#4, A#4
            [440.00, 0.5, 0.05],  // A4
            [349.23, 0.5, 0.05],  // F4
            [392.00, 0.5, 0.05],  // G4
            [349.23, 1.2, 0.3]    // F4
        ];

        function playSound(type) {
            if (isMuted) return;
            try {
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume();
                }
                const now = audioCtx.currentTime;

                if (type === 'click') {
                    const osc = audioCtx.createOscillator();
                    const gain = audioCtx.createGain();
                    osc.connect(gain);
                    gain.connect(audioCtx.destination);
                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(600, now);
                    osc.frequency.exponentialRampToValueAtTime(300, now + 0.1);
                    gain.gain.setValueAtTime(0.08, now);
                    gain.gain.linearRampToValueAtTime(0.001, now + 0.1);
                    osc.start(now);
                    osc.stop(now + 0.12);
                } else if (type === 'item') {
                    const notes = [523.25, 659.25, 783.99, 1046.50];
                    notes.forEach((freq, idx) => {
                        const oscSeq = audioCtx.createOscillator();
                        const gainSeq = audioCtx.createGain();
                        oscSeq.connect(gainSeq);
                        gainSeq.connect(audioCtx.destination);
                        oscSeq.type = 'triangle';
                        oscSeq.frequency.setValueAtTime(freq, now + idx * 0.07);
                        gainSeq.gain.setValueAtTime(0.06, now + idx * 0.07);
                        gainSeq.gain.exponentialRampToValueAtTime(0.001, now + idx * 0.07 + 0.25);
                        oscSeq.start(now + idx * 0.07);
                        oscSeq.stop(now + idx * 0.07 + 0.3);
                    });
                } else if (type === 'fanfare') {
                    const chords = [523.25, 659.25, 783.99, 987.77, 1046.50];
                    chords.forEach((freq, idx) => {
                        const oscSeq = audioCtx.createOscillator();
                        const gainSeq = audioCtx.createGain();
                        oscSeq.connect(gainSeq);
                        gainSeq.connect(audioCtx.destination);
                        oscSeq.type = 'sine';
                        oscSeq.frequency.setValueAtTime(freq, now + idx * 0.05);
                        gainSeq.gain.setValueAtTime(0.05, now + idx * 0.05);
                        gainSeq.gain.exponentialRampToValueAtTime(0.001, now + idx * 0.05 + 1.5);
                        oscSeq.start(now + idx * 0.05);
                        oscSeq.stop(now + idx * 0.05 + 1.8);
                    });
                } else if (type === 'blow') {
                    const bufferSize = audioCtx.sampleRate * 0.3;
                    const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
                    const data = buffer.getChannelData(0);
                    for (let i = 0; i < bufferSize; i++) {
                        data[i] = Math.random() * 2 - 1;
                    }
                    const noise = audioCtx.createBufferSource();
                    noise.buffer = buffer;
                    const filter = audioCtx.createBiquadFilter();
                    filter.type = 'lowpass';
                    filter.frequency.setValueAtTime(600, now);
                    filter.frequency.exponentialRampToValueAtTime(80, now + 0.3);
                    
                    const noiseGain = audioCtx.createGain();
                    noiseGain.gain.setValueAtTime(0.12, now);
                    noiseGain.gain.linearRampToValueAtTime(0.001, now + 0.3);

                    noise.connect(filter);
                    filter.connect(noiseGain);
                    noiseGain.connect(audioCtx.destination);
                    noise.start(now);
                    noise.stop(now + 0.3);
                } else if (type === 'rustle') {
                    const osc = audioCtx.createOscillator();
                    const gain = audioCtx.createGain();
                    osc.connect(gain);
                    gain.connect(audioCtx.destination);
                    osc.type = 'triangle';
                    osc.frequency.setValueAtTime(120, now);
                    osc.frequency.exponentialRampToValueAtTime(40, now + 0.15);
                    gain.gain.setValueAtTime(0.1, now);
                    gain.gain.linearRampToValueAtTime(0.001, now + 0.15);
                    osc.start(now);
                    osc.stop(now + 0.16);
                }
            } catch (e) {
                console.log("Audio play blocked:", e);
            }
        }

        function startMusic() {
            if (isMuted || isMusicPlaying) return;
            isMusicPlaying = true;
            currentNoteIndex = 0;
            document.getElementById('music-btn').innerText = "🎵 BGM: ON";

            function playNextNote() {
                if (!isMusicPlaying) return;
                const note = happyBirthdayMelody[currentNoteIndex];
                const now = audioCtx.currentTime;

                const osc = audioCtx.createOscillator();
                const gain = audioCtx.createGain();
                osc.connect(gain);
                gain.connect(audioCtx.destination);

                osc.type = 'sine';
                osc.frequency.setValueAtTime(note[0], now);
                
                gain.gain.setValueAtTime(0, now);
                gain.gain.linearRampToValueAtTime(0.03, now + 0.02);
                gain.gain.exponentialRampToValueAtTime(0.0001, now + note[1]);

                osc.start(now);
                osc.stop(now + note[1]);

                const duration = (note[1] + note[2]) * 1000;
                currentNoteIndex = (currentNoteIndex + 1) % happyBirthdayMelody.length;

                bgmIntervalId = setTimeout(playNextNote, duration);
            }

            playNextNote();
        }

        function stopMusic() {
            isMusicPlaying = false;
            if (bgmIntervalId) {
                clearTimeout(bgmIntervalId);
                bgmIntervalId = null;
            }
            document.getElementById('music-btn').innerText = "🎵 BGM: OFF";
        }

        function toggleMusic() {
            if (isMusicPlaying) {
                stopMusic();
            } else {
                if (audioCtx.state === 'suspended') {
                    audioCtx.resume();
                }
                startMusic();
                playSound('click');
            }
        }

        function toggleMute() {
            isMuted = !isMuted;
            const btn = document.getElementById('mute-btn');
            if (isMuted) {
                btn.innerHTML = '🔇 SOUND: OFF';
                stopMusic();
            } else {
                btn.innerHTML = '🔊 SOUND: ON';
                playSound('click');
            }
        }


        // --- ゲーム状態管理 ---
        const state = {
            playerName: "主役",
            currentScene: "title",
            inventory: [],
            unlocked: {
                shop: false,
                park: false,
                hideout: false
            },
            searched: {
                fridgeOpened: false,
                fridgeInsideChecked: false,
                mudChecked: false,
                parkGrassRustleCount: 0,
                parkKeyFound: false,
                shopStrawberryChecked: false
            },
            aiNegotiationState: "start",
            decorations: {
                strawberries: 0,
                creams: 0,
                plateText: "HAPPY BIRTHDAY"
            },
            candlesLit: [true, true, true]
        };

        // インタラクティブなシーン用SVGパーツジェネレータ
        const SVG_FACTORY = {
            title: () => `
                <svg viewBox="0 0 400 340" class="w-full h-full p-4 fade-in" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="400" height="340" rx="20" fill="#FAF8F5"/>
                    <g class="floating">
                        <!-- プレゼント箱 -->
                        <rect x="150" y="100" width="100" height="100" rx="12" fill="#D4A373" />
                        <rect x="190" y="100" width="20" height="100" fill="#E6DFD3" />
                        <rect x="150" y="140" width="100" height="20" fill="#E6DFD3" />
                        <!-- リボンループ -->
                        <path d="M185 100C185 75 200 75 200 100" stroke="#E6DFD3" stroke-width="8" stroke-linecap="round"/>
                        <path d="M215 100C215 75 200 75 200 100" stroke="#E6DFD3" stroke-width="8" stroke-linecap="round"/>
                        <!-- キラキラ -->
                        <path d="M120 80L125 90L135 95L125 100L120 110L115 100L105 95L115 90Z" fill="#F4EFE6" />
                    </g>
                    <!-- スタイリッシュライン -->
                    <line x1="80" y1="260" x2="320" y2="260" stroke="#E6DFD3" stroke-width="3" stroke-linecap="round"/>
                    <circle cx="200" cy="260" r="6" fill="#85705D" />
                </svg>
            `,
            fridge: () => {
                const fridgePath = state.searched.fridgeOpened 
                    ? `
                        <!-- 開いた冷蔵庫の内部 -->
                        <rect x="110" y="40" width="180" height="250" rx="12" fill="#EBE4D8" stroke="#85705D" stroke-width="4"/>
                        <!-- 冷蔵庫の仕切り棚 -->
                        <line x1="110" y1="120" x2="290" y2="120" stroke="#85705D" stroke-width="2"/>
                        <line x1="110" y1="190" x2="290" y2="190" stroke="#85705D" stroke-width="2"/>
                        
                        <!-- ケーキのあった空きスペース（点線） -->
                        <rect x="140" y="135" width="120" height="45" rx="4" stroke="#85705D" stroke-width="2" stroke-dasharray="4 4" fill="none" opacity="0.6"/>
                        <text x="160" y="162" fill="#85705D" font-size="10" font-weight="bold" opacity="0.6">CAKE MISSING</text>
                        
                        <!-- 落ちているレシート -->
                        ${!hasItem("雑貨屋のレシート") ? `
                            <g class="interactive-element" onclick="clickSceneElement('receipt')">
                                <rect x="135" y="210" width="35" height="20" rx="2" fill="white" stroke="#85705D" stroke-width="1.5" transform="rotate(-10 135 210)"/>
                                <line x1="140" y1="215" x2="160" y2="211" stroke="#85705D" stroke-width="1" />
                                <line x1="142" y1="221" x2="155" y2="218" stroke="#85705D" stroke-width="1" />
                            </g>
                        ` : ''}

                        <!-- 開いた扉 -->
                        <rect x="290" y="50" width="60" height="230" rx="6" fill="#E6DFD3" stroke="#85705D" stroke-width="4"/>
                        <line x1="290" y1="140" x2="350" y2="140" stroke="#85705D" stroke-width="2"/>
                    ` 
                    : `
                        <!-- 閉じた冷蔵庫 -->
                        <g class="interactive-element" onclick="clickSceneElement('open_fridge')">
                            <rect x="130" y="40" width="140" height="250" rx="12" fill="#E6DFD3" stroke="#85705D" stroke-width="4"/>
                            <line x1="130" y1="130" x2="270" y2="130" stroke="#85705D" stroke-width="3"/>
                            <rect x="145" y="80" width="10" height="35" rx="4" fill="#85705D"/>
                            <rect x="145" y="150" width="10" height="55" rx="4" fill="#85705D"/>
                        </g>
                    `;

                return `
                    <svg viewBox="0 0 400 340" class="w-full h-full p-4 fade-in" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect width="400" height="340" rx="20" fill="#FAF8F5"/>
                        
                        ${fridgePath}

                        <!-- 床の泥の足跡 -->
                        ${!hasItem("泥 of 泥跡") && !hasItem("泥の跡") ? `
                            <g class="interactive-element" onclick="clickSceneElement('mud')">
                                <ellipse cx="180" cy="305" rx="9" ry="4" fill="#A39281" opacity="0.6"/>
                                <ellipse cx="205" cy="315" rx="10" ry="5" fill="#A39281" opacity="0.6"/>
                                <ellipse cx="230" cy="318" rx="7" ry="3" fill="#A39281" opacity="0.4"/>
                                <text x="172" y="295" fill="#A39281" font-size="8" font-weight="bold">👣 泥の跡...?</text>
                            </g>
                        ` : ''}
                    </svg>
                `;
            },
            shop: () => `
                <svg viewBox="0 0 400 340" class="w-full h-full p-4 fade-in" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="400" height="340" rx="20" fill="#FAF8F5"/>
                    <path d="M80 60H320L300 90H100L80 60Z" fill="#D4A373"/>
                    <rect x="90" y="90" width="220" height="170" fill="white" stroke="#85705D" stroke-width="4"/>
                    <line x1="100" y1="180" x2="300" y2="180" stroke="#85705D" stroke-width="2"/>
                    
                    <!-- イチゴケース -->
                    ${!hasItem("極上イチゴ") ? `
                        <g class="interactive-element" onclick="clickSceneElement('strawberry')">
                            <rect x="115" y="145" width="40" height="30" rx="4" fill="#F4EFE6" stroke="#85705D" stroke-width="2"/>
                            <circle cx="125" cy="155" r="4" fill="#E27373"/>
                            <circle cx="135" cy="165" r="4" fill="#E27373"/>
                            <circle cx="145" cy="155" r="4" fill="#E27373"/>
                            <text x="112" y="135" fill="#E27373" font-size="8" font-weight="bold">🍓 輝くイチゴ</text>
                        </g>
                    ` : `
                        <rect x="115" y="155" width="40" height="20" rx="4" fill="#EBE4D8" stroke="#85705D" stroke-width="2" stroke-dasharray="2 2" opacity="0.5"/>
                    `}

                    <!-- ガラスびん -->
                    <rect x="235" y="135" width="25" height="40" rx="6" fill="#FAF8F5" stroke="#85705D" stroke-width="2"/>
                    <circle cx="247" cy="155" r="6" fill="#CCD5AE" />

                    <!-- 店主 -->
                    <circle cx="200" cy="210" r="24" fill="#EBE4D8" stroke="#85705D" stroke-width="3"/>
                    <path d="M175 245C175 225 225 225 225 245" fill="#85705D"/>
                    <circle cx="192" cy="208" r="5" stroke="#85705D" stroke-width="2"/>
                    <circle cx="208" cy="208" r="5" stroke="#85705D" stroke-width="2"/>
                    <line x1="197" y1="208" x2="203" y2="208" stroke="#85705D" stroke-width="2"/>
                </svg>
            `,
            park: () => {
                let grassOffset = state.searched.parkGrassRustleCount * 12;
                let grassLeftWidth = 60 - grassOffset;
                let grassRightWidth = 60 - grassOffset;
                if (grassLeftWidth < 10) grassLeftWidth = 0;
                if (grassRightWidth < 10) grassRightWidth = 0;

                return `
