                    document.getElementById('ai-input-panel').classList.remove('hidden');

                    initAiChat();

                    const actionPanel = document.getElementById('action-panel');
                    let buttonsHTML = ``;

                    if (hasItem("極上イチゴ")) {
                        buttonsHTML += `<button onclick="useStrawberryOnLabi()" class="w-full bg-[#E27373] hover:bg-[#C15C5C] text-white py-2.5 px-4 rounded-xl text-xs font-bold transition-all shadow-sm">🍓 「極上イチゴ」をラビにプレゼントして誘う</button>`;
                    }

                    buttonsHTML += `<button onclick="forceReclaim()" class="w-full bg-white hover:bg-[#FAF8F5] text-[#85705D] border border-[#E6DFD3] py-2 px-4 rounded-xl text-xs font-semibold transition-all">😠 「コラ！盗みはダメだ！」とケーキを取り上げる</button>`;

                    actionPanel.innerHTML = buttonsHTML;
                }
            },
            decorating: {
                location: "デコレーション工房",
                text: () => `ケーキは無傷で回収された！さらにラビも一緒にパーティーでお祝いすることに合意。\nさあ、仕上げとして主役の【 ${state.playerName} 】にふさわしい、最高のオリジナルケーキへDIYデコレーションしよう！\n\n「イチゴ」や「ホップ」をたっぷりのせて、華やかに仕上げてくださいね。`,
                render: () => {
                    showHeader();
                    document.getElementById('ai-chat-box').classList.add('hidden');
                    document.getElementById('ai-input-panel').classList.add('hidden');

                    const container = document.getElementById('visual-area');
                    container.innerHTML = SVG_FACTORY.decorating();

                    const actionPanel = document.getElementById('action-panel');
                    actionPanel.innerHTML = `
                        <div class="mb-2">
                            <label class="block text-[9px] font-bold text-[#85705D] mb-0.5">チョコプレートのメッセージ変更</label>
                            <input type="text" id="plate-text-input" value="${state.decorations.plateText}" oninput="updatePlateText(this.value)" class="w-full px-3 py-1.5 border border-[#E6DFD3] rounded-lg text-xs font-bold bg-white text-[#4A433D]">
                        </div>
                        <button onclick="finishDecorating()" class="w-full bg-[#85705D] hover:bg-[#6F5B4B] text-white font-bold py-3 px-4 rounded-xl text-xs tracking-widest transition-all shadow-md">
                            🎉 デコレーションを完成させてパーティーを開始する！
                        </button>
                    `;
                }
            },
            celebration: {
                location: "ハッピーバースデーパーティー！",
                text: () => `✨🎉 MISSION COMPLETE !! 🎉✨\n\nお祝い特製ケーキを素晴らしいデコレーションで奪還することに成功した！\n新しい仲間となったウサギのラビも、お祝いクラッカーを持ってスタンバイ完了！\n\n【 ${state.playerName} 】、本当にお誕生日おめでとうございます！🎂✨\n\n（ケーキの上のロウソクの火を、息を吹きかけるようにタップまたはクリックしてすべて消してね！）`,
                render: () => {
                    const container = document.getElementById('visual-area');
                    container.innerHTML = SVG_FACTORY.celebration();

                    startConfetti();

                    const actionPanel = document.getElementById('action-panel');
                    actionPanel.innerHTML = `
                        <button onclick="resetGame()" class="w-full bg-[#85705D] hover:bg-[#6F5B4B] text-white font-bold py-3 px-4 rounded-xl text-xs tracking-wider transition-all">
                            🔄 もう一度最初から遊ぶ
                        </button>
                    `;
                }
            }
        };


        // --- Gemini API リアルタイム交渉チャット実装 ---
        let chatHistory = [];

        function initAiChat() {
            const chatBox = document.getElementById('ai-chat-box');
            chatBox.innerHTML = `
                <div class="bg-[#FAF8F5] p-2 rounded-lg border border-[#EBE4D8] leading-normal text-[#5E4E42]">
                    <span class="font-bold text-[#E27373]">ラビ:</span> うぅぅ…ごめんなさい、ボク怒られるのすごく怖いよぅ……。ボクだって誰かとお祝いしたかっただけんだもん……。
                </div>
            `;
            chatHistory = [
                { role: "user", parts: [{ text: "ゲームの状況：プレイヤー（ケーキ捜査官エージェント）が、寂しがりのウサギ妖精ラビ（あなた）のアジトを突き止めた。ラビは泣いて怯えている。穏和にケーキを返してもらい、仲間になるように対話する。" }] },
                { role: "model", parts: [{ text: "うぅぅ…ごめんなさい、ボク怒られるのすごく怖いよぅ……。ボクだって誰かとお祝いしたかっただけんだもん……。" }] }
            ];
            scrollLogToBottom();
        }

        async function sendChatMessage() {
            const inputEl = document.getElementById('ai-user-text');
            const message = inputEl.value.trim();
            if (!message) return;

            inputEl.value = "";
            playSound('click');

            const chatBox = document.getElementById('ai-chat-box');
            chatBox.innerHTML += `
                <div class="bg-[#F0EAE1] p-2 rounded-lg text-[#3D3530] text-right self-end max-w-[90%] ml-auto font-medium">
                    ${escapeHTML(message)}
                </div>
            `;
            scrollLogToBottom();

            const loadingId = "ai-loading-" + Date.now();
            chatBox.innerHTML += `
                <div id="${loadingId}" class="bg-[#FAF8F5] p-2 rounded-lg border border-[#EBE4D8] text-gray-400 italic">
                    ラビが考え中...
                </div>
            `;
            scrollLogToBottom();

            const apiKey = "";
            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;

            const systemPrompt = `あなたは誕生日ケーキをこっそり盗んでしまった、非常に寂しがり屋で繊細なウサギの妖精「ラビ」です。
現在アジトでケーキを抱えて怯えています。プレイヤーがあなたを説得しようとしています。
ラビのルール：
- 一人称は「ボク」。おどおどした幼児のような可愛い口調（「〜だよぅ」「〜だもん」「うぅ…」など）で答えてください。
- 本当は悪い子ではなく、寂しいからお腹いっぱいケーキを食べたかった。
- プレイヤーが「優しくしてくれる」「ケーキを一緒に食べようと誘う」「怒らない」「友達になろう」などの優しいアプローチをすると大喜びして、ケーキを返して一緒にパーティーに参加することに同意します。
- 同意した場合（説得が成功した場合）、会話テキストの最後に、必ず「[SUCCESS]」という特殊タグを1つ付加してください。
- プレイヤーが「警察を呼ぶ」「叱りつける」「厳しく取り立てる」など威圧的・冷酷なアプローチをしてきた場合、怯えて拒絶し、最後に必ず「[FAIL]」を付加してください。
- 1回の応答は必ず短め（2〜3文、100文字以内）にまとめてください。`;

            chatHistory.push({ role: "user", parts: [{ text: message }] });

            try {
                const response = await fetch(apiUrl, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: chatHistory,
                        systemInstruction: { parts: [{ text: systemPrompt }] }
                    })
                });

                const data = await response.json();
                const aiReply = data?.candidates?.[0]?.content?.parts?.[0]?.text || "うぅ、なんて言ったらいいか分からないよぅ……。";

                const loadEl = document.getElementById(loadingId);
                if (loadEl) loadEl.remove();

                let finalReply = aiReply;
                let isSuccess = false;
                let isFail = false;

                if (finalReply.includes("[SUCCESS]")) {
                    isSuccess = true;
                    finalReply = finalReply.replace("[SUCCESS]", "").trim();
                }
                if (finalReply.includes("[FAIL]")) {
                    isFail = true;
                    finalReply = finalReply.replace("[FAIL]", "").trim();
                }

                chatBox.innerHTML += `
                    <div class="bg-[#FAF8F5] p-2 rounded-lg border border-[#EBE4D8] leading-normal text-[#5E4E42]">
                        <span class="font-bold text-[#E27373]">ラビ:</span> ${escapeHTML(finalReply)}
                    </div>
                `;
                scrollLogToBottom();

                chatHistory.push({ role: "model", parts: [{ text: aiReply }] });

                if (isSuccess) {
                    setTimeout(() => {
                        playSound('fanfare');
                        state.aiNegotiationState = "success";
                        changeScene('decorating');
                    }, 1200);
                } else if (isFail) {
                    playSound('click');
                }

            } catch (err) {
                console.error(err);
                const loadEl = document.getElementById(loadingId);
                if (loadEl) loadEl.remove();
                
                let aiReply = "うぅ、ボクそんなに悪い子じゃないのにぃ……。";
                let isSuccess = false;
                
                if (message.includes("イチゴ") || message.includes("いちご") || message.includes("一緒") || message.includes("いいよ") || message.includes("友達") || message.includes("許す") || message.includes("おいで")) {
                    aiReply = "えっ！？本当に！？一緒にお祝いしてもいいの……！？イチゴもくれるのぅ！？うわぁぁん、ありがとうぉ！ボク、ケーキお返しするし、一緒にパーティー行きたい！";
                    isSuccess = true;
                }

                chatBox.innerHTML += `
                    <div class="bg-[#FAF8F5] p-2 rounded-lg border border-[#EBE4D8] leading-normal text-[#5E4E42]">
                        <span class="font-bold text-[#E27373]">ラビ:</span> ${aiReply}
                    </div>
                `;
                scrollLogToBottom();

                if (isSuccess) {
                    setTimeout(() => {
                        playSound('fanfare');
                        state.aiNegotiationState = "success";
                        changeScene('decorating');
                    }, 1200);
                }
            }
        }

        function useStrawberryOnLabi() {
            playSound('fanfare');
            removeItem("極上イチゴ");
            const chatBox = document.getElementById('ai-chat-box');
            chatBox.innerHTML += `
                <div class="bg-[#F0EAE1] p-2 rounded-lg text-[#3D3530] text-right self-end max-w-[90%] ml-auto font-medium">
                    🍓 極上イチゴをプレゼントした！「一緒に食べよう！」
                </div>
            `;
            setTimeout(() => {
                chatBox.innerHTML += `
                    <div class="bg-[#FAF8F5] p-2 rounded-lg border border-[#EBE4D8] leading-normal text-[#5E4E42]">
                        <span class="font-bold text-[#E27373]">ラビ:</span> うわぁぁぁ！これ、ボクが大好きな一番甘い高級いちごしゃん！！……うぅ、こんなに優しくしてもらえるなんて……ごめんなさい！ケーキ返すし、ボクもパーティーお手伝いするぅ！
                    </div>
                `;
                scrollLogToBottom();
                setTimeout(() => {
                    changeScene('decorating');
                }, 1500);
            }, 500);
        }

        function forceReclaim() {
            playSound('click');
            const chatBox = document.getElementById('ai-chat-box');
            chatBox.innerHTML += `
                <div class="bg-[#FAF8F5] p-2 rounded-lg border border-red-200 leading-normal text-red-500">
                    <span class="font-bold">ラビ:</span> うわぁぁん！ごめんなさい、やっぱり怒られたぁ！！
                </div>
            `;
            scrollLogToBottom();
            const textLog = document.getElementById('dialogue-text');
            textLog.textContent = "ラビはケーキをその場に置いたまま、号泣してどこかへ逃げてしまった。誰の手も傷つかずにミッションは遂行されたが、どこか心が痛む寂しい結果だ……。\n\n（本当にこれでいいのだろうか？ウサギの妖精も笑顔にできる、もっと良いアプローチがあったのではないだろうか？）";

            const actionPanel = document.getElementById('action-panel');
            actionPanel.innerHTML = `
                <button onclick="goToMap()" class="w-full bg-[#85705D] hover:bg-[#6F5B4B] text-white py-2.5 px-4 rounded-xl text-xs font-semibold transition-all shadow-md">📍 GPSマップに戻って捜査をやり直す</button>
            `;
        }


        // --- ケーキ・カスタムデコレーション＆お祝い演出 ---
        function updatePlateText(val) {
            state.decorations.plateText = val.toUpperCase();
            const container = document.getElementById('visual-area');
            container.innerHTML = SVG_FACTORY.decorating();
        }

        function finishDecorating() {
            playSound('fanfare');
            changeScene('celebration');
        }

        function blowCandle(idx) {
            if (!state.candlesLit[idx]) return;
            state.candlesLit[idx] = false;
            playSound('blow');
            
            const container = document.getElementById('visual-area');
            container.innerHTML = SVG_FACTORY.celebration();

            const allOut = state.candlesLit.every(lit => !lit);
            if (allOut) {
                setTimeout(() => {
                    playSound('fanfare');
                    const textLog = document.getElementById('dialogue-text');
                    textLog.innerHTML = `
                        <span class="text-[#E27373] font-bold text-lg block mb-2 font-cinzel tracking-wider">✨ HAPPY BIRTHDAY TO YOU !! ✨</span>
                        見事にすべてのキャンドルが吹き消されました！🎂🕵️‍♂️🕯️\nこれであなたの新しい1年間は、幸せとワクワクに満ちた素晴らしいミッションで溢れることでしょう！\n\nラビやエージェント仲間と一緒に、最高にハッピーなお誕生日をお過ごしください！🎁🎉
                    `;
                }, 600);
            }
        }


        // --- ポイント＆クリック要素クリック時の分岐処理 ---
        function clickSceneElement(elementId) {
            if (elementId === 'open_fridge') {
                playSound('click');
                state.searched.fridgeOpened = true;
                changeScene('fridge');
            } else if (elementId === 'receipt') {
                gainItem("雑貨屋のレシート", "📄", "1時間前に発行されたレシート。");
                state.unlocked.shop = true;
                changeScene('fridge');
            } else if (elementId === 'mud') {
                gainItem("泥の跡", "👣", "水分を含んだ黒い泥の痕跡。");
                state.unlocked.park = true;
                changeScene('fridge');
            } else if (elementId === 'strawberry') {
                playSound('click');
                state.searched.shopStrawberryChecked = true;
                const textLog = document.getElementById('dialogue-text');
                textLog.textContent = `店主に特製ケーキ盗難について聞き取りを行うと、大慌てで言った。\n\n「ああっ、ケーキを泥棒したのだとしたらさっきの白いお耳のウサギの妖精さんだ！慌てて走って行ったよ！そういえばこれ、あの子がお祝い用に購入したお釣りを忘れていってね……お詫びと言ってはなんだが、彼の好物の【極上イチゴ】をお譲りしよう。説得の役に立てておくれ！」`;
                gainItem("極上イチゴ", "🍓", "店主から授かったツヤツヤの極上いちご。");
                changeScene('shop');
            } else if (elementId === 'grass') {
                rustleGrass();
            } else if (elementId === 'key') {
                gainItem("アジトの鍵", "🔑", "公園の茂みの奥に隠されていた真鍮製の鍵。");
                state.searched.parkKeyFound = true;
                state.unlocked.hideout = true;
                changeScene('park');
            } else if (elementId === 'add_strawberry') {
                if (state.decorations.strawberries < 5) {
                    playSound('click');
                    state.decorations.strawberries++;
                    changeScene('decorating');
                }
            } else if (elementId === 'add_cream') {
                if (state.decorations.creams < 7) {
                    playSound('click');
                    state.decorations.creams++;
                    changeScene('decorating');
                }
            } else if (elementId.startsWith('candle_')) {
                const idx = parseInt(elementId.split('_')[1], 10);
                blowCandle(idx);
            }
        }

        function rustleGrass() {
            playSound('rustle');
            state.searched.parkGrassRustleCount++;
            changeScene('park');
        }


        // --- パーティクル（紙吹雪）アニメーション ---
        let confettiActive = false;
        const confettis = [];
        const confettiColors = ['#E27373', '#CCD5AE', '#D4A373', '#FAF8F5', '#EBE4D8'];

        function startConfetti() {
            confettiActive = true;
            const canvas = document.getElementById('confetti-canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;

            for (let i = 0; i < 80; i++) {
                confettis.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height - canvas.height,
                    size: Math.random() * 6 + 4,
                    color: confettiColors[Math.floor(Math.random() * confettiColors.length)],
                    speed: Math.random() * 3 + 1,
                    rotation: Math.random() * 360,
                    rotationSpeed: Math.random() * 4 - 2
                });
            }

            function updateConfetti() {
                if (!confettiActive) return;
                ctx.clearRect(0, 0, canvas.width, canvas.height);

                confettis.forEach(c => {
                    c.y += c.speed;
                    c.rotation += c.rotationSpeed;
                    if (c.y > canvas.height) {
                        c.y = -10;
                        c.x = Math.random() * canvas.width;
                    }

                    ctx.save();
                    ctx.translate(c.x, c.y);
                    ctx.rotate((c.rotation * Math.PI) / 180);
                    ctx.fillStyle = c.color;
                    ctx.fillRect(-c.size / 2, -c.size / 2, c.size, c.size);
                    ctx.restore();
                });

                requestAnimationFrame(updateConfetti);
            }

            updateConfetti();
        }

        function stopConfetti() {
            confettiActive = false;
            const canvas = document.getElementById('confetti-canvas');
            const ctx = canvas.getContext('2d');
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            confettis.length = 0;
        }


        // --- 各種UI操作ヘルプ & システム汎用関数 ---
        function showHeader() {
            document.getElementById('game-header').classList.remove('hidden');
        }

        function updateInventoryUI() {
            // ループを4つに拡張
            for (let i = 0; i < 4; i++) {
                const slot = document.getElementById(`slot-${i}`);
                if (state.inventory[i]) {
                    const item = state.inventory[i];
                    slot.innerHTML = item.icon;
                    slot.title = `${item.name}: ${item.desc}`;
                    slot.className = "w-8 h-8 rounded-lg border border-[#D4A373] bg-[#FAF8F5] flex items-center justify-center text-sm relative cursor-pointer opacity-100 scale-105 transition-all";
                } else {
                    slot.innerHTML = "📁";
                    slot.title = "空きスロット";
                    slot.className = "w-8 h-8 rounded-lg border border-[#E6DFD3] bg-white/60 flex items-center justify-center text-sm opacity-40 transition-all";
                }
            }
        }

        function hasItem(itemName) {
            return state.inventory.some(item => item.name === itemName);
        }

        function gainItem(name, icon, desc) {
            // 最大所持数を4に拡張
            if (state.inventory.length >= 4) return false;
            state.inventory.push({ name, icon, desc });
            playSound('item');
            updateInventoryUI();
            
            const textLog = document.getElementById('dialogue-text');
            const original = textLog.innerHTML;
            textLog.innerHTML = `<span class="text-[#D4A373] font-bold">✨ 証拠品【${name}】を獲得！</span>\n\n` + original;
            return true;
        }

        function removeItem(name) {
            state.inventory = state.inventory.filter(item => item.name !== name);
            updateInventoryUI();
        }

        function changeScene(sceneId) {
            state.currentScene = sceneId;
            const scene = scenes[sceneId];
            
            document.getElementById('location-indicator').textContent = scene.location;
            
            const textContainer = document.getElementById('dialogue-text');
            textContainer.textContent = "";
            const rawText = typeof scene.text === 'function' ? scene.text() : scene.text;
            
            let charIndex = 0;
            let displayedText = "";
            
            function typeChar() {
                if (state.currentScene !== sceneId) return;
                if (charIndex < rawText.length) {
                    displayedText += rawText[charIndex];
                    textContainer.textContent = displayedText;
                    charIndex++;
                    setTimeout(typeChar, 10);
                }
            }
            typeChar();

            scene.render();
            updateInventoryUI();
        }

        function startGame() {
            const inputVal = document.getElementById('player-name-input').value.trim();
            if (inputVal) {
                state.playerName = inputVal;
                state.decorations.plateText = "HPB " + inputVal.toUpperCase();
            }
            
            if (isMuted) toggleMute();
            startMusic();
            
            changeScene('fridge');
        }

        function goToMap() {
            changeScene('map');
        }

        function unlockHideout() {
            playSound('click');
            removeItem("アジトの鍵");
            changeScene('thiefRoom');
        }

        function scrollLogToBottom() {
            const logBox = document.getElementById('text-log-container');
            setTimeout(() => {
                logBox.scrollTop = logBox.scrollHeight;
            }, 50);
        }

        function escapeHTML(str) {
            return str.replace(/[&<>'"]/g, 
                tag => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[tag] || tag)
            );
        }

        function resetGame() {
            stopConfetti();
            state.playerName = "主役";
            state.currentScene = "title";
            state.inventory = [];
            state.unlocked = { shop: false, park: false, hideout: false };
            state.searched = {
                fridgeOpened: false,
                fridgeInsideChecked: false,
                mudChecked: false,
                parkGrassRustleCount: 0,
                parkKeyFound: false,
                shopStrawberryChecked: false
            };
            state.aiNegotiationState = "start";
            state.decorations = { strawberries: 0, creams: 0, plateText: "HAPPY BIRTHDAY" };
            state.candlesLit = [true, true, true];
            
            changeScene('title');
        }

        window.onload = () => {
            changeScene('title');
        };
    </script>
